# ── Groq (LLM) ──────────────────────────────────────────────────────────────
# Get from https://console.groq.com → API Keys
GROQ_API=your_groq_api_key_here

# ── PageIndex (Document Indexing) ────────────────────────────────────────────
# Get from https://pageindex.ai → Dashboard → API Keys
PAGE_INDEX_API=your_pageindex_api_key_here

# ── Clerk (Authentication) ───────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk Webhook signing secret
# Get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Required for syncing users to DB on sign-up/update
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from https://neon.tech → your project → Connection string
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# ── Frontend URL (for CORS / Clerk authorized parties) ───────────────────────
CLIENT_URL=http://localhost:3000
